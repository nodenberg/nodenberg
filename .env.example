# Server Configuration
PORT=3000

# API Authentication (required)
# IMPORTANT: Set a strong API key for security
API_KEY=your-secret-api-key-here

# Example: Generate a secure random key using openssl
# API_KEY=$(openssl rand -base64 32)

# Environment (optional)
# NODE_ENV=production

# Image layout debug (optional)
# Set true to print image box/scale/anchor calculations to server logs
# DEBUG_IMAGE_LAYOUT=false

# LibreOffice command debug (optional)
# Set true to print the resolved soffice path and --version before PDF conversion
# DEBUG_SOFFICE_COMMAND=false
